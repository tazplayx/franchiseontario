# ── Stripe Keys ──────────────────────────────────────────────────────
# Get these from your Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...            # Use sk_test_... for testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...  # Use pk_test_... for testing

# ── Stripe Webhook Secret ─────────────────────────────────────────────
# After deploying, create a webhook in Stripe Dashboard → Developers → Webhooks
# Endpoint URL: https://www.franchiseontario.com/api/stripe/webhook
# Events to listen for:
#   - checkout.session.completed
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - invoice.paid
#   - invoice.payment_failed
# Then paste the "Signing secret" (whsec_...) below:
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ──────────────────────────────────────────────────
# Create these in Stripe Dashboard → Products:
#
# Product 1: "FranchiseOntario Premium Listing"
#   - Price: $79.00 CAD / month (recurring)
#   - Copy the Price ID (price_...) below
STRIPE_PRICE_PREMIUM=price_...

# Product 2: "FranchiseOntario Enterprise Listing"
#   - Price: $199.00 CAD / month (recurring)
STRIPE_PRICE_ENTERPRISE=price_...

# Product 3: "Homepage Feature Spotlight"
#   - Price: $14.99 CAD / week (recurring)
STRIPE_PRICE_FEATURE_SPOTLIGHT=price_...

# ── App URL ───────────────────────────────────────────────────────────
# Used for Stripe success/cancel redirect URLs
NEXT_PUBLIC_BASE_URL=https://www.franchiseontario.com
# For local development use: http://localhost:3002

# ── Stripe Tax Setup ─────────────────────────────────────────────────
# To enable automatic HST/GST calculation:
# 1. Go to Stripe Dashboard → Settings → Tax
# 2. Enable Stripe Tax
# 3. Add your tax registration:
#    - Country: Canada
#    - Province: Ontario
#    - Tax type: HST
#    - Your HST registration number
# 4. Stripe will automatically calculate and display 13% HST for ON
#    and appropriate GST/PST for other provinces at checkout.
# 5. Stripe Tax remits collected taxes on your behalf in eligible regions.
#    For Canada, you are responsible for remitting to the CRA.
#    Stripe provides detailed tax reports under Dashboard → Tax → Reports.
